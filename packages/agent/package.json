{
	"name": "@edith/agent",
	"version": "3.0.0",
	"type": "module",
	"scripts": {
		"start": "bun edith.ts",
		"dev": "bun --watch --no-clear-screen edith.ts",
		"test": "bun test tests/",
		"test:coverage": "bun test tests/scheduler.test.ts tests/geo.test.ts tests/mcp-tools.test.ts tests/taskboard.test.ts tests/screenpipe.test.ts tests/dispatch.test.ts tests/briefs.test.ts --coverage && bun test tests/handlers.test.ts && bun test tests/dispatch-integration.test.ts",
		"test:e2e": "bash test-e2e.sh",
		"setup": "bash setup.sh",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.83",
		"@arizeai/openinference-instrumentation-claude-agent-sdk": "^0.2.0",
		"@google/generative-ai": "^0.24.1",
		"@langfuse/otel": "^5.0.1",
		"@logtail/node": "^0.5.8",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/sdk-node": "^0.214.0",
		"googleapis": "^171.4.0",
		"zod": "^4.3.6"
	}
}
