{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Edith",
	"version": "0.1.0",
	"identifier": "dev.edith.app",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"macOSPrivateApi": true,
		"windows": [
			{
				"label": "main",
				"title": "Edith",
				"width": 320,
				"height": 480,
				"resizable": true,
				"decorations": false,
				"transparent": true,
				"alwaysOnTop": true,
				"skipTaskbar": true,
				"x": 1100,
				"y": 100
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"macOS": {
			"signingIdentity": null,
			"infoPlist": {
				"NSScreenCaptureUsageDescription": "Edith uses screen capture to understand your context and proactively assist you.",
				"NSMicrophoneUsageDescription": "Edith uses the microphone for ambient audio capture and voice input."
			}
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	},
	"plugins": {
		"updater": {
			"pubkey": "PLACEHOLDER_UPDATER_PUBLIC_KEY",
			"endpoints": ["https://github.com/randywilson/edith-v3/releases/latest/download/latest.json"],
			"dialog": false
		}
	}
}
