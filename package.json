{
  "name": "edith",
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "start": "./launch-edith.sh",
    "dashboard": "bun dashboard.ts",
    "test": "bun test tests/",
    "test:e2e": "bash test-e2e.sh",
    "setup": "bash setup.sh",
    "docker": "docker compose up -d",
    "stop": "bash -c 'PID=$(cat ~/.edith/edith.pid 2>/dev/null) && kill $PID 2>/dev/null && echo \"Edith stopped (PID $PID)\" || echo \"Edith not running\"'",
    "prepare": "husky"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "husky": "^9.1.7"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.83",
    "@arizeai/openinference-instrumentation-claude-agent-sdk": "^0.2.0",
    "@google/generative-ai": "^0.24.1",
    "@langfuse/otel": "^5.0.1",
    "@logtail/node": "^0.5.8",
    "@opentelemetry/sdk-node": "^0.214.0"
  }
}
