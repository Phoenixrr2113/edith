{
	"name": "edith-monorepo",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"packageManager": "bun@1.3.8",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run test",
		"lint": "turbo run lint",
		"typecheck": "turbo run typecheck",
		"start": "bun run --cwd packages/agent start",
		"dashboard": "bun run --cwd packages/agent dashboard",
		"docker": "docker compose up -d",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"bun-types": "^1.3.11",
		"husky": "^9.1.7",
		"turbo": "^2.9.1"
	},
	"dependencies": {
		"@types/node": "^25.5.0"
	}
}
